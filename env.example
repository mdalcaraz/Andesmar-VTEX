NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------------------------------------------------------------------------
# VTEX — Credenciales por cuenta
# ---------------------------------------------------------------------------
# Las credenciales VTEX (AppKey, AppToken, BaseUrl, GetOrdersUrl) se almacenan
# en la tabla `clienteVtex` de la base de datos, una fila por tienda.
# Esto permite soportar múltiples cuentas VTEX sin cambiar el .env.
#
# Las variables de abajo son valores de FALLBACK: se usan solo si una fila de
# `clienteVtex` no tiene sus propios campos VTEX completos (VtexAppKey, etc.).
# Para instalaciones nuevas donde todas las cuentas están cargadas en DB,
# estas variables pueden omitirse.
#
# VTEX_BASE_URL=https://mitienda.myvtex.com
# VTEX_APP_KEY=vtexappkey-mitienda-XXXXXX
# VTEX_APP_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# VTEX_GET_ORDERS_URL=https://mitienda.vtexcommercestable.com.br/api/oms/pvt/orders

# ---------------------------------------------------------------------------
# VTEX — Cron de reconciliación de órdenes
# ---------------------------------------------------------------------------
# Expresión cron para la frecuencia de ejecución (default: cada 45 minutos)
VTEX_GET_ORDERS_CRON_EXPRESSION=*/45 * * * *
# Horas hacia atrás que se consultan en cada corrida
VTEX_GET_ORDERS_CRON_WINDOW_HOURS=3
# Habilitar o deshabilitar el cron (true/false)
VTEX_GET_ORDERS_CRON_ENABLED=true
# Modo prueba: fuerza un rango de fechas fijo en lugar de la ventana dinámica
VTEX_GET_ORDERS_USE_TEST_WINDOW=false
VTEX_GET_ORDERS_TEST_FROM=2024-12-03T13:59:39.000Z
VTEX_GET_ORDERS_TEST_TO=2026-12-03T15:59:39.000Z

# ---------------------------------------------------------------------------
# VTEX — Cron de actualización de estados
# ---------------------------------------------------------------------------
VTEX_UPDATE_STATUS_CRON_EXPRESSION=*/15 * * * *
VTEX_UPDATE_STATUS_CRON_ENABLED=false

# ---------------------------------------------------------------------------
# Base de datos — SQL Server
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_INSTANCE=SQLEXPRESS
DB_NAME=my_app_db
DB_USER=sa
DB_PASSWORD=YourStrong!Passw0rd
DB_DIALECT=mssql
DB_LOGGING=false

# ---------------------------------------------------------------------------
# Andesmar API
# ---------------------------------------------------------------------------
ANDESMAR_BASE_URL=https://api.andesmarcargas.com
ANDESMAR_INSERTAR_PEDIDO_PATH=/api/InsertPedidoMulti
# En desarrollo apunta a apitest; en producción reemplazar por la URL productiva
ANDESMAR_CALCULAR_MONTO_URL=https://apitest.andesmarcargas.com/api/CalcularMonto
ANDESMAR_TIMEOUT_MS=60000
# Token Bearer usado para validar los webhooks entrantes de VTEX
ANDESMAR_GENERATED_TOKEN=reemplazar_con_token_seguro
