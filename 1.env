NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- CRON de reconciliación de órdenes VTEX ---
# Expresión cron (por defecto: cada 45 minutos)
VTEX_GET_ORDERS_CRON_EXPRESSION=*/45 * * * *
# Ventana de tiempo hacia atrás (en horas) que se va a revisar en cada corrida
VTEX_GET_ORDERS_CRON_WINDOW_HOURS=3
# Habilitar / deshabilitar el cron
VTEX_GET_ORDERS_CRON_ENABLED=true
# Para pruebas del filtro VTEX (si está en true, usa el rango hardcodeado)
VTEX_GET_ORDERS_USE_TEST_WINDOW=false
# Rango fijo de pruebas
VTEX_GET_ORDERS_TEST_FROM=2024-12-03T13:59:39.000Z
VTEX_GET_ORDERS_TEST_TO=2026-12-03T15:59:39.000Z

# --- CRON de actualización de estado de órdenes VTEX ---
# Expresión cron (por defecto: cada 15 minutos)
VTEX_UPDATE_STATUS_CRON_EXPRESSION=*/15 * * * *
# Habilitar / deshabilitar el cron
VTEX_UPDATE_STATUS_CRON_ENABLED=true

# --- Base de datos ---
DB_HOST=LUJAN
DB_INSTANCE=SPKTEST
DB_NAME=sispack
DB_USER=sa
DB_PASSWORD=Viseva2017
DB_DIALECT=mssql
DB_LOGGING=false

# --- Andesmar API ---
ANDESMAR_BASE_URL=https://api.andesmarcargas.com
ANDESMAR_INSERTAR_PEDIDO_PATH=/api/InsertPedidoMulti
ANDESMAR_CALCULAR_MONTO_URL=https://apitest.andesmarcargas.com/api/CalcularMonto
ANDESMAR_TIMEOUT_MS=60000

# Token para autenticar los webhooks recibidos desde VTEX
ANDESMAR_GENERATED_TOKEN=tokendePrueba
